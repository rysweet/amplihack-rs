  }
  subgraph cluster_7 { label="Foundation"; style=filled; color="#eef";
    "amplihack-types";
    "amplihack-utils";
    "amplihack-builders";
  }
  subgraph cluster_8 { label="Security & safety"; style=filled; color="#eef";
    "amplihack-security";
    "amplihack-safety";
  }
  subgraph cluster_9 { label="Code analysis"; style=filled; color="#eef";
    "amplihack-blarify";
    "amplihack-multilspy";
  }
  "amplihack" -> "amplihack-cli";
  "amplihack" -> "amplihack-hooks";
