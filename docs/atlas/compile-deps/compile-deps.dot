digraph compile_deps {
  rankdir=LR; node [shape=box,style=rounded,fontsize=10];
  labelloc=t; label="amplihack-rs internal crate dependencies";
  subgraph cluster_0 { label="Entry points (bins)"; style=filled; color="#eef";
    "amplihack";
    "amplihack-hooks-bin";
    "amplihack-asset-resolver-bin";
  }
  subgraph cluster_1 { label="CLI core"; style=filled; color="#eef";
